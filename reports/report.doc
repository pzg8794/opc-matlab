{\pard\plain \li1500\sl-448\slmult0 \ql{\f25\fs10 {\fs39 \sub s}{\fs39 \sub (}{\fs39 \sub x; \sub y}{\fs39 \sub ) \sub =} {\fs39 \sub e} {\fs27 \super j}{\fs27 \super 2  \super (}{\fs27 \super u}0{\fs27 \super x}{\fs27 \super +}{\fs27 \super v}0{\fs27 \super y}{\fs27 \super )}}\par}
}
{\pard\sl-176\slmult0\par

{\pard\plain \li0\sl-223\slmult0 \ri0\nooverflow\qj{\f11\fs19 The lter has a real and an imaginary component repre-senting orthogonal directions. The two components may be formed into a complex number or used individually [3].}\par}
}\column

